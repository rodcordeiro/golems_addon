{
	"format_version": "1.21.10",
	"minecraft:item": {
		"description": {
			"identifier": "fv:steel_pickaxe",
			"menu_category": {
				"category": "equipment",
				"group": "itemGroup.name.pickaxe"
			}
		},
		"components": {
