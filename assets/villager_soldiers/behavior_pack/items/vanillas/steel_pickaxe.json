				"use_efficiency": true,
				"destroy_speeds": [
					{
						"block": {
							"tags": "query.any_tag('minecraft:diamond_tier_destructible')"
						},
						"speed": 6
					},
					{
						"block": {
							"tags": "query.any_tag('stone', 'metal', 'minecraft:is_pickaxe_item_destructible', 'minecraft:iron_tier_destructible')"
						},
						"speed": 7
					},
					{
						"block": "minecraft:ice",
						"speed": 7
					},
					{
						"block": "minecraft:sandstone",
						"speed": 7
					}
				]
			},
			"minecraft:tags": {
				"tags": [
					"minecraft:is_pickaxe",
					"fv:steel_tier"
				]
			},
			"minecraft:custom_components": [
				"fv:on_mine_block"
			]
		}
