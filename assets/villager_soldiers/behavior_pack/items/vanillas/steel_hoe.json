{
	"format_version": "1.21.10",
	"minecraft:item": {
		"description": {
			"identifier": "fv:steel_hoe",
			"menu_category": {
				"category": "equipment",
				"group": "itemGroup.name.hoe"
			}
		},
		"components": {
			"minecraft:max_stack_size": 1,
			"minecraft:hand_equipped": true,
			"minecraft:durability": {
				"max_durability": 1080
			},
			"minecraft:icon": "fv_steel_hoe",
			"minecraft:damage": 0,
			"minecraft:enchantable": {
				"value": 14,
				"slot": "hoe"
			},
			"minecraft:digger": {
				"use_efficiency": true,
				"destroy_speeds": [
					{
						"block": {
							"tags": "query.any_tag('minecraft:is_hoe_item_destructible')"
						},
						"speed": 7
					}
				]
			},
			"minecraft:repairable": {
				"repair_items": [
					{
						"items": [
							"fv:steel_ingot"
						],
						"repair_amount": "query.max_durability*0.25"
					},
					{
						"items": [
							"fv:steel_hoe"
						],
						"repair_amount": "context.other->query.remaining_durability+0.12*context.other->query.max_durability"
					}
				]
			},
			"minecraft:tags": {
				"tags": [
					"minecraft:is_hoe",
					"fv:steel_tier"
				]
			},
			"minecraft:interact_button": true,
			"minecraft:custom_components": [
				"fv:hoe_use",
				"fv:durability_loss_on_use_on",
				"fv:durability_loss_on_mine_block"
			]
		}
	}
}