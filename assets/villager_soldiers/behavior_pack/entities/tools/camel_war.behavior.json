{
	"format_version": "1.16.0",
	"minecraft:entity": {
		"description": {
			"identifier": "fv:camel_war",
			"is_spawnable": true,
			"is_summonable": true,
			"is_experimental": false
		},
		"component_groups": {
			"minecraft:pig_baby": {
				"minecraft:is_baby": {},
				"minecraft:scale": {
					"value": 0.45
				},
				"minecraft:ageable": {
					"duration": 1200,
					"feed_items": [
						"cactus"
					],
					"grow_up": {
						"event": "minecraft:ageable_grow_up",
						"target": "self"
					}
				},
				"minecraft:behavior.follow_parent": {
					"priority": 6,
					"speed_multiplier": 1.1
				}
			},
			"minecraft:pig_adult": {
				"minecraft:experience_reward": {
					"on_bred": "math.random(1,7)",
					"on_death": "query.last_hit_by_player?math.random(1,3):0"
				},
				"minecraft:behavior.breed": {
					"priority": 4,
					"speed_multiplier": 1
				},
				"minecraft:breedable": {
					"require_tame": false,
					"breeds_with": {
						"mate_type": "fv:camel_war",
						"baby_type": "fv:camel_war",
						"breed_event": {
							"event": "minecraft:entity_born",
							"target": "baby"
						}
					},
					"breed_items": [
						"cactus"
					]
				}
			},
			"minecraft:pig_saddled": {
				"minecraft:is_saddled": {}
			},
			"despawn": {
				"minecraft:instant_despawn": {
					"remove_child_entities": false
				}
			}
		},
		"components": {
			"minecraft:type_family": {
				"family": [
					"camel",
					"canelwar",
					"mob"
				]
			},
			"minecraft:breathable": {
				"total_supply": 15,
				"suffocate_time": 0
			},
			"minecraft:nameable": {},
			"minecraft:health": {
				"value": 60,
				"max": 60
			},
			"minecraft:hurt_on_condition": {
				"damage_conditions": [
					{
						"filters": {
							"test": "in_lava",
							"subject": "self",
							"operator": "==",
							"value": true
						},
						"cause": "lava",
						"damage_per_tick": 4
					}
				]
			},
			"minecraft:movement": {
				"value": 0.25
			},
			"minecraft:navigation.walk": {
				"can_path_over_water": true,
				"avoid_water": true,
				"avoid_damage_blocks": true
			},
			"minecraft:movement.basic": {},
			"minecraft:jump.static": {},
			"minecraft:can_climb": {},
			"minecraft:collision_box": {
				"width": 1.7,
				"height": 2.375
			},
			"minecraft:leashable": {
				"soft_distance": 4,
				"hard_distance": 6,
				"max_distance": 10
			},
			"minecraft:balloonable": {
				"mass": 0.75
			},
			"minecraft:behavior.float": {
				"priority": 2
			},
			"minecraft:behavior.panic": {
				"priority": 3,
				"speed_multiplier": 1.25
			},
			"minecraft:behavior.tempt": {
				"priority": 5,
				"speed_multiplier": 1.2,
				"items": [
					"cactus"
				]
			},
			"minecraft:behavior.random_stroll": {
				"priority": 7,
				"speed_multiplier": 1
			},
			"minecraft:behavior.look_at_player": {
				"priority": 8,
				"look_distance": 6,
				"probability": 0.02
			},
			"minecraft:behavior.random_look_around": {
				"priority": 9
			},
			"minecraft:physics": {},
			"minecraft:pushable": {
				"is_pushable": true,
				"is_pushable_by_piston": true
			},
			"minecraft:conditional_bandwidth_optimization": {},
			"minecraft:interact": {
				"interactions": [
					{
						"on_interact": {
							"filters": {
								"all_of": [
									{
										"test": "has_equipment",
										"subject": "other",
										"domain": "hand",
										"value": "saddle"
									},
									{
										"test": "has_component",
										"subject": "self",
										"operator": "!=",
										"value": "minecraft:is_baby"
									},
									{
										"test": "has_component",
										"subject": "self",
										"operator": "!=",
										"value": "minecraft:is_saddled"
									}
								]
							},
							"event": "minecraft:on_saddled"
						},
						"use_item": true,
						"play_sounds": "saddle",
						"interact_text": "action.interact.saddle"
					},
					{
						"add_items": {
							"table": "loot_tables/get_camel_war.json"
						},
						"interact_text": "action.interact.get",
						"on_interact": {
							"filters": {
								"all_of": [
									{
										"test": "has_component",
										"subject": "self",
										"operator": "==",
										"value": "minecraft:is_saddled"
									},
									{
										"test": "is_sneaking",
										"subject": "player",
										"value": true
									}
								]
							},
							"event": "despawn",
							"target": "self"
						}
					}
				]
			}
		},
		"events": {
			"minecraft:entity_spawned": {
				"sequence": [
					{
						"filters": {
							"all_of": [
								{
									"test": "has_equipment",
									"subject": "other",
									"operator": "!=",
									"value": "fv:camel_war_baby"
								},
								{
									"test": "has_equipment",
									"subject": "other",
									"operator": "!=",
									"value": "fv:camel_war_saddled"
								}
							]
						},
						"randomize": [
							{
								"weight": 95,
								"add": {
									"component_groups": [
										"minecraft:pig_adult"
									]
								}
							},
							{
								"weight": 5,
								"remove": {},
								"add": {
									"component_groups": [
										"minecraft:pig_baby"
									]
								}
							}
						]
					},
					{
						"filters": {
							"test": "has_equipment",
							"subject": "other",
							"operator": "==",
							"value": "fv:camel_war_baby"
						},
						"add": {
							"component_groups": [
								"minecraft:pig_baby"
							]
						}
					},
					{
						"filters": {
							"test": "has_equipment",
							"subject": "other",
							"operator": "==",
							"value": "fv:camel_war_saddled"
						},
						"add": {
							"component_groups": [
								"minecraft:pig_adult",
								"minecraft:pig_saddled"
							]
						}
					}
				]
			},
			"minecraft:entity_born": {
				"remove": {},
				"add": {
					"component_groups": [
						"minecraft:pig_baby"
					]
				}
			},
			"minecraft:ageable_grow_up": {
				"remove": {
					"component_groups": [
						"minecraft:pig_baby"
					]
				},
				"add": {
					"component_groups": [
						"minecraft:pig_adult"
					]
				}
			},
			"minecraft:on_saddled": {
				"add": {
					"component_groups": [
						"minecraft:pig_saddled"
					]
				}
			},
			"minecraft:spawn_adult": {
				"add": {
					"component_groups": [
						"minecraft:pig_adult"
					]
				}
			},
			"despawn": {
				"add": {
					"component_groups": [
						"despawn"
					]
				}
			},
			"drop": {
				"add": {
					"component_groups": [
						"minecraft:pig_adult",
						"minecraft:pig_saddled"
					]
				}
			}
		}
	}
}