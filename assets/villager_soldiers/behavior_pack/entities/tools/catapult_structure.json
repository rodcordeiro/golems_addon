{
	"format_version": "1.21.60",
	"minecraft:entity": {
		"description": {
			"identifier": "fv:catapult_structure",
			"is_summonable": true,
			"is_spawnable": true,
			"properties": {
				"fv:step": {
					"type": "int",
					"range": [
						0,
						5
					],
					"default": 0,
					"client_sync": true
				}
			},
			"animations": {
				"structure_catapult": "controller.animation.structure_catapult"
			},
			"scripts": {
				"animate": [
					"structure_catapult"
				]
			}
		},
		"component_groups": {
			"hitbox_1": {
				"minecraft:collision_box": {
					"height": 0.5,
					"width": 2.1
				}
			},
			"hitbox_2": {
				"minecraft:collision_box": {
					"height": 1.3,
					"width": 2.1
				}
			},
			"hitbox_3": {
				"minecraft:collision_box": {
					"height": 2.6,
					"width": 2.1
				}
			},
			"become_catapult": {
				"minecraft:transformation": {
					"into": "fv:catapult"
				}
			}
		},
		"components": {
			"minecraft:health": {
				"value": 100,
				"max": 100
			},
			"minecraft:type_family": {
				"family": [
					"structure_building"
				]
			},
			"minecraft:scale": {
				"value": 2
			},
			"minecraft:knockback_resistance": {
				"value": 100,
				"max": 100
			},
			"minecraft:physics": {},
			"minecraft:pushable": {
				"is_pushable": false,
				"is_pushable_by_piston": true
			},
			"minecraft:damage_sensor": {
				"triggers": [
					{
						"on_damage": {
							"filters": {
								"test": "has_damage",
								"subject": "self",
								"operator": "==",
								"value": "fatal"
							},
							"event": "become_catapult"
						}
					},
					{
						"on_damage": {
							"filters": {
								"all_of": [
									{
										"test": "has_equipment",
										"subject": "other",
										"operator": "!=",
										"value": "fv:get_back_hammer"
									},
									{
										"test": "has_equipment",
										"subject": "other",
										"operator": "!=",
										"value": "fv:copper_wrench"
									}
								]
							}
						},
						"deals_damage": "no"
					}
				]
			}
		},
		"events": {
			"minecraft:entity_spawned": {
				"add": {
					"component_groups": [
						"hitbox_1"
					]
				}
			},
			"step1": {
				"set_property": {
					"fv:step": 1
				}
			},
			"step2": {
				"set_property": {
					"fv:step": 2
				}
			},
			"step3": {
				"set_property": {
					"fv:step": 3
				},
				"add": {
					"component_groups": [
						"hitbox_2"
					]
				}
			},
			"step4": {
				"set_property": {
					"fv:step": 4
				},
				"add": {
					"component_groups": [
						"hitbox_3"
					]
				}
			},
			"step5": {
				"set_property": {
					"fv:step": 5
				}
			},
			"become_catapult": {
				"add": {
					"component_groups": [
						"become_catapult"
					]
				}
			}
		}
	}
}