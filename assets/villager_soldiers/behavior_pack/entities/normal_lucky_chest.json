{
	"format_version": "1.21.90",
	"minecraft:entity": {
		"description": {
			"identifier": "fv:normal_lucky_chest",
			"is_spawnable": true,
			"is_summonable": true,
			"is_experimental": false
		},
		"component_groups": {
			"spawn": {
				"minecraft:timer": {
					"time": 0.5,
					"time_down_event": {
						"event": "can_open",
						"target": "self"
					}
				}
			},
			"can_open": {
				"minecraft:interact": {
					"interactions": [
						{
							"spawn_items": {
								"table": "loot_tables/lucky_chest/normal.json"
							},
							"interact_text": "action.interact.opencontainer",
							"on_interact": {
								"event": "opend",
								"target": "self"
							}
						}
					]
				}
			},
			"opened": {
				"minecraft:timer": {
					"time": 1,
					"time_down_event": {
						"event": "despawn",
						"target": "self"
					}
				},
				"minecraft:variant": {
					"value": 1
				}
			},
			"despawn": {
				"minecraft:instant_despawn": {
					"remove_child_entities": true
				}
			}
		},
		"components": {
			"minecraft:variant": {
				"value": 0
			},
			"minecraft:collision_box": {
				"width": 1,
				"height": 1
			},
			"minecraft:loot": {
				"table": "loot_tables/lucky_chest/normal.json"
			},
			"minecraft:physics": {},
			"minecraft:pushable": {
				"is_pushable": false,
				"is_pushable_by_piston": false
			},
			"minecraft:conditional_bandwidth_optimization": {
				"default_values": {
					"max_optimized_distance": 60,
					"max_dropped_ticks": 20,
					"use_motion_prediction_hints": true
				},
				"conditional_values": [
					{
						"max_optimized_distance": 0,
						"max_dropped_ticks": 0,
						"conditional_values": [
							{
								"test": "is_moving",
								"subject": "self",
								"operator": "==",
								"value": true
							}
						]
					}
				]
			},
			"minecraft:damage_sensor": {
				"triggers": {
					"cause": "all",
					"deals_damage": "no"
				}
			}
		},
		"events": {
			"minecraft:entity_spawned": {
				"add": {
					"component_groups": [
						"spawn"
					]
				}
			},
			"opend": {
				"add": {
					"component_groups": [
						"opened"
					]
				},
				"remove": {
					"component_groups": [
						"can_open"
					]
				}
			},
			"despawn": {
				"add": {
					"component_groups": [
						"despawn"
					]
				},
				"remove": {
					"component_groups": [
						"opened"
					]
				}
			},
			"can_open": {
				"add": {
					"component_groups": [
						"can_open"
					]
				},
				"remove": {
					"component_groups": [
						"spawn"
					]
				}
			}
		}
	}
}