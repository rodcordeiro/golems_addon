{
	"format_version": "1.21.60",
	"minecraft:entity": {
		"description": {
			"identifier": "fv:big_potato_cannon",
			"is_summonable": true,
			"is_spawnable": true,
			"properties": {
				"fv:canshoot": {
					"type": "bool",
					"default": false,
					"client_sync": true
				},
				"fv:potato_type": {
					"type": "enum",
					"values": [
						"empty",
						"normal",
						"exp"
					],
					"default": "empty"
				},
				"fv:shooting": {
					"type": "bool",
					"default": false,
					"client_sync": true
				}
			}
		},
		"component_groups": {
			"timer": {
				"minecraft:timer": {
					"time": 2,
					"time_down_event": {
						"event": "shooted",
						"target": "self"
					}
				}
			},
			"despawn": {
				"minecraft:instant_despawn": {
					"remove_child_entities": false
				},
				"minecraft:spawn_entity": {
					"entities": [
						{
							"min_wait_time": 0,
							"max_wait_time": 0,
							"num_to_spawn": 1,
							"single_use": true,
							"spawn_item": "fv:big_potato_cannon"
						}
					]
				}
			}
		},
		"components": {
			"minecraft:collision_box": {
				"height": 0.7,
				"width": 0.6
			},
			"minecraft:type_family": {
				"family": [
					"cannon",
					"potatocannon"
				]
			},
			"minecraft:health": {
				"value": 60,
				"max": 60
			},
			"minecraft:interact": {
				"interactions": [
					{
						"hurt_item": 1,
						"interact_text": "action.interact.potato.shoot",
						"swing": true,
						"on_interact": {
							"filters": {
								"all_of": [
									{
										"test": "bool_property",
										"domain": "fv:canshoot",
										"subject": "self",
										"value": true
									},
									{
										"test": "has_equipment",
										"subject": "player",
										"operator": "==",
										"value": "flint_and_steel"
									},
									{
										"test": "bool_property",
										"domain": "fv:shooting",
										"subject": "self",
										"value": false
									}
								]
							},
							"event": "shooting",
							"target": "self"
						}
					}
				]
			},
			"minecraft:physics": {},
			"minecraft:pushable": {
				"is_pushable": false,
				"is_pushable_by_piston": true
			},
			"minecraft:conditional_bandwidth_optimization": {},
			"minecraft:damage_sensor": {
				"triggers": [
					{
						"cause": "fall",
						"deals_damage": "no"
					},
					{
						"on_damage": {
							"filters": {
								"all_of": [
									{
										"test": "is_family",
										"subject": "other",
										"value": "irongolem"
									},
									{
										"test": "has_component",
										"subject": "self",
										"operator": "!=",
										"value": "minecraft:is_tamed"
									}
								]
							}
						},
						"deals_damage": "no"
					},
					{
						"on_damage": {
							"filters": {
								"all_of": [
									{
										"test": "is_family",
										"subject": "other",
										"value": "player"
									},
									{
										"test": "has_equipment",
										"subject": "other",
										"operator": "==",
										"value": "fv:get_back_hammer"
									}
								]
							},
							"event": "despawn",
							"target": "self"
						},
						"deals_damage": "no"
					}
				]
			},
			"minecraft:knockback_resistance": {
				"value": 1
			},
			"minecraft:inventory": {
				"inventory_size": 2,
				"container_type": "inventory"
			}
		},
		"events": {
			"shooting": {
				"set_property": {
					"fv:shooting": true
				},
				"add": {
					"component_groups": [
						"timer"
					]
				},
				"queue_command": {
					"command": [
						"playsound potato.cannon.shoot @a ~ ~ ~ 2",
						"scriptevent bigcannon:shoot @s"
					]
				}
			},
			"shooted": {
				"set_property": {
					"fv:shooting": false
				},
				"remove": {
					"component_groups": [
						"timer"
					]
				}
			},
			"despawn": {
				"add": {
					"component_groups": [
						"despawn"
					]
				}
			}
		}
	}
}