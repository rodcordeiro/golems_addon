							"filters": {
								"all_of": [
									{
										"any_of": [
											{
												"test": "enum_property",
												"domain": "fv:reload",
												"subject": "self",
												"operator": "==",
												"value": "potato"
											},
											{
												"test": "enum_property",
												"domain": "fv:reload",
												"subject": "self",
