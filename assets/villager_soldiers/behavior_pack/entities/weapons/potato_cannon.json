			"gunpower_reloaded": {
				"set_property": {
					"fv:reload": "gunpower"
				},
				"queue_command": {
					"command": "playsound block.bamboo.hit @a ~ ~ ~"
				}
			},
			"potato_reloaded": {
				"set_property": {
					"fv:reload": "potato"
				},
				"queue_command": {
					"command": "playsound block.bamboo.step @a ~ ~ ~"
				}
			},
			"potato_exp_reloaded": {
				"set_property": {
					"fv:reload": "potatoexp"
				},
				"queue_command": {
					"command": "playsound block.bamboo.step @a ~ ~ ~"
				}
			},
			"shooting": {
				"set_property": {
					"fv:shooting": true
				},
				"add": {
					"component_groups": [
						"timer"
					]
				},
				"queue_command": {
					"command": [
						"playsound potato.cannon.shoot @a ~ ~ ~ 2",
						"scriptevent cannon:shoot @s"
					]
				}
			},
			"shooted": {
				"set_property": {
					"fv:shooting": false
				},
				"remove": {
					"component_groups": [
						"timer"
					]
				}
			},
			"despawn": {
				"add": {
					"component_groups": [
						"despawn"
					]
				}
			}
