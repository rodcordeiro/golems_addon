						"cause": "fall",
						"deals_damage": "no"
					},
					{
						"on_damage": {
							"filters": {
								"all_of": [
									{
										"test": "is_family",
										"subject": "other",
										"value": "irongolem"
									},
									{
										"test": "has_component",
										"subject": "self",
										"operator": "!=",
										"value": "minecraft:is_tamed"
									}
								]
							}
						},
						"deals_damage": "no"
