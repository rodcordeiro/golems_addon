										"operator": "==",
										"value": "gunpower"
									},
									{
										"test": "has_equipment",
										"subject": "player",
										"operator": "==",
										"value": "fv:potato_explode"
									},
									{
										"test": "bool_property",
										"domain": "fv:shooting",
										"subject": "self",
