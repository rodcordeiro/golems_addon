				"set_property": {
					"fv:golden_reaper_ammo": "8",
					"fv:reloading": "none",
					"fv:is_reloading": false
				}
			},
			"fv:reaper_reloading": {
				"add": {
					"component_groups": [
						"fv:reaper_reload"
					]
				},
				"remove": {
					"component_groups": [
						"fv:deadlight_rifle",
						"fv:golden_reaper",
						"fv:sensor",
						"fv:rifle_reload"
					]
