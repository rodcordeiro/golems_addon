			},
			"fv:rifle_shoot": {
				"set_property": {
					"fv:deadlight_rifle_ammo": "query.property('fv:deadlight_rifle_ammo') - 1"
				}
			},
			"fv:reaper_shoot": {
				"set_property": {
					"fv:golden_reaper_ammo": "query.property('fv:golden_reaper_ammo') - 1"
