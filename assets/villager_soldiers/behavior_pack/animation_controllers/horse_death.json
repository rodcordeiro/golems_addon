{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.horse.death": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"death": "!query.is_alive"
						}
					]
				},
				"death": {
					"on_entry": [
						"/event entity @s drop"
					]
				}
			}
		}
	}
}