				"default": {
					"transitions": [
						{
							"stay": "query.property('fv:stay_mode')==true"
						}
					]
				},
				"stay": {
					"on_entry": [
						"/effect @s slowness infinite 255 true"
					],
					"on_exit": [
						"/effect @s clear slowness"
					],
					"transitions": [
						{
							"default": "query.property('fv:stay_mode')==false"
						}
					]
				}
			}
