{
	"format_version": "1.8.0",
	"render_controllers": {
		"controller.render.vindicator.armor": {
			"geometry": "geometry.armor",
			"part_visibility": [
				{
					"arm1": "query.is_angry || query.is_celebrating"
				},
				{
					"arm2": "query.is_angry || query.is_celebrating"
				},
				{
					"armor5": "!(query.is_angry || query.is_celebrating)"
				}
			],
			"materials": [
				{
					"*": "material.default"
				}
			],
			"textures": [
				"array.skin[query.variant]"
			],
			"arrays": {
				"textures": {
					"Array.skin": [
						"Texture.normal",
						"Texture.captain"
					]
				}
			}
		}
	}
}