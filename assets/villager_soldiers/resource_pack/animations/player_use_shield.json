{
	"format_version": "1.8.0",
	"animations": {
		"animation.player.use_shield_main_hand": {
			"loop": true,
			"bones": {
				"rightarm": {
					"rotation": [
						"!v.is_first_person?-20:0",
						"!v.is_first_person?-30:0",
						"!v.is_first_person?-25:0"
					]
				},
				"rightitem": {
					"position": [
						"!v.is_first_person?-1:0",
						"!v.is_first_person?-3:0",
						0
					],
					"rotation": [
						0,
						"!v.is_first_person?-60:0",
						"!v.is_first_person?-45:0"
					]
				}
			}
		},
		"animation.player.use_shield_off_hand": {
			"loop": true,
			"bones": {
				"leftarm": {
					"rotation": [
						"!v.is_first_person?-20:0",
						"!v.is_first_person?20:0",
						"!v.is_first_person?20:0"
					]
				},
				"leftitem": {
					"position": [
						"!v.is_first_person?1+query.item_is_charged*1.5:0",
						"!v.is_first_person?-3+query.item_is_charged:0",
						0
					],
					"rotation": [
						"!v.is_first_person?query.item_is_charged*30:0",
						"!v.is_first_person?70-query.item_is_charged*60:0",
						"!v.is_first_person?65-query.item_is_charged*15:0"
					]
				}
			}
		}
	}
}