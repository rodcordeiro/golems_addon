{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.spear.fpt.using": {
			"initial_state": "default",
			"states": {
				"default": {
					"animations": [
						"first_persion"
					],
					"blend_transition": 0.3,
					"transitions": [
						{
							"using": "query.is_using_item"
						}
					]
				},
				"using": {
					"animations": [
						"first_persion_using"
					],
					"blend_transition": 0.3,
					"transitions": [
						{
							"attacked": "!query.is_using_item"
						}
					]
				},
				"attacked": {
					"animations": [
						"first_persion_attacked"
					],
					"blend_transition": 0.5,
					"transitions": [
						{
							"default": "query.all_animations_finished"
						}
					]
				}
			}
		},
		"controller.animation.spear.particle.using": {
			"initial_state": "default",
			"states": {
