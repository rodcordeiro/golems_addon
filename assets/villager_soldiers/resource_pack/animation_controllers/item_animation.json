						{
							"attacked": "!query.is_using_item"
						}
					]
				},
				"attacked": {
					"animations": [
						"spear_particle"
					],
					"blend_transition": 0.3,
					"transitions": [
						{
							"default": "query.all_animations_finished"
						}
					]
				}
			}
		},
		"controller.animation.guns.flintlock_musket.general": {
