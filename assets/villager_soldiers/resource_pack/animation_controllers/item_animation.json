		"controller.animation.guns.handle_cannon.general": {
			"initial_state": "default",
			"states": {
				"default": {
					"animations": [
						{
							"fpp": "c.is_first_person"
						},
						{
							"tpp": "!c.is_first_person"
						}
					],
					"blend_transition": 0.1,
					"transitions": [
						{
							"using": "query.main_hand_item_use_duration>0&&!query.item_is_charged"
						}
					]
				},
				"using": {
					"animations": [
						"reloading",
						{
							"wield_first_person_pull": "c.is_first_person"
						},
						{
							"fpp_pull": "c.is_first_person"
						},
						{
							"tpp_pull": "!c.is_first_person"
						}
					],
					"blend_transition": 0.1,
					"transitions": [
						{
							"default": "query.main_hand_item_use_duration==0"
						}
					]
				}
			}
		},
		"controller.animation.guns.handle_cannon_v2.reloading": {
			"initial_state": "default",
			"states": {
