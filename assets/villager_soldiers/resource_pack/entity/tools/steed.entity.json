{
	"format_version": "1.10.0",
	"minecraft:client_entity": {
		"description": {
			"identifier": "fv:steed",
			"materials": {
				"default": "horse_leather_armor"
			},
			"textures": {
				"base_brown": "textures/entity/fv_steed/horse_brown",
				"base_white": "textures/entity/fv_steed/horse_white",
				"base_creamy": "textures/entity/fv_steed/horse_creamy",
				"base_chestnut": "textures/entity/fv_steed/horse_chestnut",
				"base_black": "textures/entity/fv_steed/horse_black",
				"base_gray": "textures/entity/fv_steed/horse_gray",
				"base_darkbrown": "textures/entity/fv_steed/horse_darkbrown",
				"markings_none": "textures/entity/fv_steed/horse_markings_none",
				"markings_white": "textures/entity/fv_steed/horse_markings_white",
				"markings_whitefield": "textures/entity/fv_steed/horse_markings_whitefield",
				"markings_whitedots": "textures/entity/fv_steed/horse_markings_whitedots",
				"markings_blackdots": "textures/entity/fv_steed/horse_markings_blackdots",
				"armor_none": "textures/entity/fv_steed/armor/horse_armor_none",
				"armor_leather": "textures/entity/fv_steed/armor/horse_armor_leather",
				"armor_iron": "textures/entity/fv_steed/armor/horse_armor_iron",
				"armor_gold": "textures/entity/fv_steed/armor/horse_armor_gold",
				"armor_diamond": "textures/entity/fv_steed/armor/horse_armor_diamond"
			},
			"geometry": {
				"default": "geometry.steed"
			},
			"animations": {
				"baby_transform": "animation.steed.baby_transform",
				"walk": "animation.steed.walk",
				"eat": "animation.steed.eat",
				"rear": "animation.steed.rear",
				"tail": "animation.steed.tail",
				"look_at_player": "animation.steed.look_at_player"
			},
			"scripts": {
				"initialize": [
					"variable.eat_anim = 0;",
					"variable.stand_anim = 0;",
					"variable.leg_stand_factor = 0;",
					"variable.leg_x_rot_anim = 0;"
				],
				"pre_animation": [
					"variable.armor_texture_slot = query.armor_texture_slot(1);",
					"variable.eat_anim = math.clamp(variable.eat_anim + (query.is_grazing ? ((1.0 - variable.eat_anim) * 0.4 + 0.05) : -variable.eat_anim * 0.4 - 0.05) * query.delta_time * 20.0, 0.0, 1.0);",
					"variable.head_x_rot = query.target_x_rotation + (query.modified_move_speed > 0.2 ? (math.cos(query.modified_distance_moved * 11.46) * 11.46 * query.modified_move_speed + query.modified_move_speed * 11.46) : 0.0);",
					"variable.inverse_max_stand_eat = (1.0 - math.max(variable.stand_anim, variable.eat_anim));",
					"variable.leg_stand_factor = math.cos((query.modified_distance_moved * 38.38) + 180.0);",
					"variable.leg_x_rot_anim = variable.leg_stand_factor * 45.8 * query.modified_move_speed;"
				],
				"animate": [
					{
						"baby_transform": "query.is_baby"
					},
					"walk",
					"look_at_player",
					{
						"rear": "variable.stand_anim>0"
					},
					{
						"eat": "!query.is_standing"
					},
					{
						"tail": "math.mod(q.life_time,10)<0.5"
					}
				]
			},
			"render_controllers": [
				"controller.render.fv_steed"
			],
			"spawn_egg": {
				"texture": "spawn_egg_horse"
			}
		}
	}
}