				"riding.legs": "animation.humanoid.riding.legs",
				"celebrating": "animation.humanoid.celebrating",
				"controller_general": "controller.animation.villager_clan_leader.general",
				"controller_move": "controller.animation.fv_villager.move",
				"controller_riding": "controller.animation.humanoid.riding_legs_only",
				"melee_attack": "animation.piglin.hand.attack"
			},
			"particle_effects": {
				"spell": "minecraft:evoker_spell"
			},
			"render_controllers": [
				"controller.render.villager_healer",
