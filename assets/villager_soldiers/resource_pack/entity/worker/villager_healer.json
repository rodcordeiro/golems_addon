{
	"format_version": "1.10.0",
	"minecraft:client_entity": {
		"description": {
			"identifier": "fv:villager_healer",
			"materials": {
				"default": "evoker"
			},
			"textures": {
				"default": "textures/entity/villager2/villager_cleric_master",
				"wrist_belt": "textures/entity/villager2/wrist_belt",
				"tamed_color": "textures/entity/villager2/tamed_color"
			},
			"geometry": {
				"default": "geometry.cleric_master",
				"wrist_belt": "geometry.wrist_belt_evoker",
				"tamed_color": "geometry.tamed_color_evoker"
