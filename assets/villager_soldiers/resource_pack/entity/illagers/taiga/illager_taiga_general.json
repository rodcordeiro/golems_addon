{
	"format_version": "1.10.0",
	"minecraft:client_entity": {
		"description": {
			"identifier": "fv:illager_taiga_general",
			"materials": {
				"default": "vindicator"
			},
			"textures": {
				"default": "textures/entity/new_illagers/taiga/illager_taiga",
				"armor": "textures/entity/illager_armor/wolf_armor",
				"cape": "textures/entity/new_illagers/taiga/taiga_cape"
			},
			"geometry": {
				"default": "geometry.repillager",
