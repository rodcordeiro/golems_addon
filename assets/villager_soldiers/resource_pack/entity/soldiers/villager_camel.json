{
	"format_version": "1.10.0",
	"minecraft:client_entity": {
		"description": {
			"identifier": "fv:villager_camel",
			"materials": {
				"default": "pillager",
				"tamed_color": "entity_alphatest_change_color"
			},
			"textures": {
				"desert": "textures/entity/sword_soldier_villager/desert",
				"jungle": "textures/entity/sword_soldier_villager/jungle",
				"plains": "textures/entity/sword_soldier_villager/plains",
				"savanna": "textures/entity/sword_soldier_villager/savanna",
				"snow": "textures/entity/sword_soldier_villager/snow",
				"swamp": "textures/entity/sword_soldier_villager/swamp",
				"taiga": "textures/entity/sword_soldier_villager/taiga",
				"camel": "textures/entity/fv_camel_war/camel",
				"royal_desert": "textures/entity/captain_banner/desert",
				"royal_jungle": "textures/entity/captain_banner/jungle",
				"royal_plains": "textures/entity/captain_banner/plains",
				"royal_savanna": "textures/entity/captain_banner/savanna",
				"royal_snow": "textures/entity/captain_banner/snow",
				"royal_swamp": "textures/entity/captain_banner/swamp",
				"royal_taiga": "textures/entity/captain_banner/taiga",
				"target": "textures/entity/target",
				"wrist_belt": "textures/entity/villager2/wrist_belt",
				"tamed_color": "textures/entity/villager2/tamed_color",
				"stay_statue": "textures/entity/stay_statue"
			},
			"geometry": {
				"default": "geometry.villager_handle",
				"camel": "geometry.soldier_camel",
				"captain_banner": "geometry.captain_banner",
				"target": "geometry.target",
				"wrist_belt": "geometry.wrist_belt",
				"tamed_color": "geometry.tamed_color",
				"stay_statue": "geometry.stay_statue"
			},
			"spawn_egg": {
				"texture": "fv_villager_soldier_spawn_egg"
			},
			"scripts": {
				"scale": "0.9375",
				"pre_animation": [
					"variable.tcos0 = (Math.cos(query.modified_distance_moved * 38.17) * query.modified_move_speed / variable.gliding_speed_value) * 57.3;",
					"variable.attack = Math.sin((1.0 - (1.0 - variable.attack_time) * (1.0 - variable.attack_time)) * 180.0) * 57.3;",
					"variable.attack2 = Math.sin(variable.attack_time * 180.0) * 57.3;",
					"variable.z_bob = Math.cos(query.life_time * 103.13244) * 2.865 + 2.865;",
					"variable.x_bob = Math.sin(query.life_time * 76.776372) * 2.865;",
					"variable.moving = query.modified_move_speed > 0.05 || query.vertical_speed > 0.05;"
				],
				"variables": {
					"variable.item_use_normalized": "public",
					"variable.tp_melee_spear_use_attachable_rotation_z": "public"
				},
				"initialize": [
					"v.tp_melee_spear_base_arm_rotation_x = -30.0;"
				],
				"animate": [
					"pillager_root_controller",
					"riding",
					{
						"dead": "!query.is_alive"
					},
					"banner",
					"armor",
					{
						"noout": "query.has_armor_slot(2)"
					},
					"irongolem",
					{
						"attack_controller": "query.variant==2||query.variant==4"
					},
					{
						"spear_attack": "query.variant==5"
					},
					{
						"melee_spear_controller": "query.variant==3"
					}
				]
			},
			"animations": {
				"humanoid_base_pose": "animation.humanoid.base_pose",
				"look_at_target_default": "animation.humanoid.look_at_target.default",
				"look_at_target_gliding": "animation.humanoid.look_at_target.gliding",
				"look_at_target_swimming": "animation.humanoid.look_at_target.swimming",
				"move": "animation.camel_riding.walking",
				"holding": "animation.humanoid.holding",
				"attack.rotations": "animation.humanoid.attack.rotations",
				"bob": "animation.humanoid.bob",
				"controller_humanoid_base_pose": "controller.animation.humanoid.base_pose",
				"controller_look_at_target": "controller.animation.humanoid.look_at_target",
				"controller_move": "controller.animation.camel.soldier.move",
				"controller_attack": "controller.animation.humanoid.attack",
				"controller_bob": "controller.animation.humanoid.bob",
				"attack_controller": "controller.animation.villager.horse.attack",
				"pillager_root_controller": "controller.animation.fv_pillager.root",
				"idle": "animation.camel_riding.idle",
				"riding": "animation.camel_riding.riding",
				"horse_hold_attack": "animation.villager_noarmor.horse_hold_attack",
				"horse_attack": "animation.villager_noarmor.horse_attack",
				"horse_default": "animation.villager_noarmor.horse_default",
				"dead": "animation.soldier_horse.dead",
				"sit": "animation.villager_noarmor.staying",
				"banner": "animation.captain_banner.default",
				"armor": "animation.villager_noarmor.armor",
				"noout": "animation.villager_noarmor.noout",
				"irongolem": "animation.target.irongolem",
				"has_target": "animation.repillager.spear.has_target",
				"attack": "animation.repillager.spear.attacked",
				"spear_attack": "controller.animation.vindicator.spearman_attack",
				"melee_spear_use": "animation.humanoid.melee_spear_use",
				"melee_spear_hold": "animation.humanoid.melee_spear_hold",
				"melee_spear_controller": "controller.animation.villager.melee_spear",
				"support_vanilla": "animation.repillager.spear.support_vanilla"
			},
			"render_controllers": [
				"controller.render.vanilla.biome",
				"controller.render.camel.soldier",
				{
					"controller.render.banner.biome": "query.is_saddled"
				},
				{
					"controller.render.golem.target": "query.property('fv:kill_player_mode')==true"
				},
				{
					"controller.render.wrist_belt": "query.is_sitting"
				},
				{
					"controller.render.tamed_color": "query.is_tamed"
				},
				{
					"controller.render.stay_statue": "query.property('fv:stay_mode')==true"
				}
			],
			"enable_attachables": true
		}
	}
}