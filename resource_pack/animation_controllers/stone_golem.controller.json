{
  "format_version": "1.8.0",
  "animation_controllers": {
    "controller.animation.stone_golem": {
      "initial_state": "idle",
      "states": {
        "idle": {
          "animations": [
            "hide_ground_block",
            "hide_rock"
          ],
          "transitions": [
            {
              "walk": "query.modified_move_speed > 0.03"
            },
            {
              "pull": "query.is_using_item"
            }
          ]
        },
        "walk": {
          "animations": [
            "hide_ground_block",
            "hide_rock",
            "walk"
          ],
          "transitions": [
            {
              "pull": "query.is_using_item"
            },
            {
              "idle": "query.modified_move_speed <= 0.03"
            }
          ]
        },
        "pull": {
          "animations": [
            "pull_block"
          ],
          "on_entry": [
            "/particle addon:ground_break ~ ~ ~"
          ],
          "transitions": [
            {
              "throw": "query.is_using_item"
            }
          ]
        },
        "throw": {
          "animations": [
            "throw"
          ],
          "transitions": [
            {
              "idle": "query.is_using_item == false"
            }
          ]
        }
      }
    }
  }
}
